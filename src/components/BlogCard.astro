---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/date";
import { getBlogPostHref } from "../lib/routes";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, date, tags, cover, excerpt } = post.data;
const formatted = formatDate(date, "short");
---

<a
  href={getBlogPostHref(post.id)}
  class="group flex flex-col border-[3px] border-ink bg-white hover:-translate-y-1 transition-transform duration-150"
>
  <!-- Cover image -->
  <div class="aspect-video overflow-hidden">
    <Image
      src={cover}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
    />
  </div>

  <!-- Body -->
  <div class="flex flex-col flex-1 px-4 pt-4 pb-3 gap-2">
    <h2 class="text-base font-bold text-ink leading-snug line-clamp-2 group-hover:text-brand transition-colors">
      {title}
    </h2>
    <p class="text-sm text-subtle line-clamp-2 flex-1">{excerpt}</p>
  </div>

  <!-- Footer -->
  <div class="bg-ink px-4 py-2.5 flex items-center justify-between gap-3">
    <time class="text-xs text-faint uppercase tracking-wider shrink-0">{formatted}</time>
    <div class="flex flex-wrap justify-end gap-1.5">
      {tags.map((tag) => (
        <span class="text-[10px] font-medium text-brand-soft bg-brand-soft/10 px-2 py-0.5">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
