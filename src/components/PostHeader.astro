---
import { formatDate } from "../lib/date";

interface Props {
  title: string;
  date: Date;
  tags: string[];
  linkTags?: boolean;
}

const { title, date, tags, linkTags = false } = Astro.props;
const formatted = formatDate(date);
const tagClass =
  "text-xs font-medium px-2.5 py-1 rounded-full bg-brand-tint text-brand-strong";
---

<div class="mb-8">
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag) => (
      linkTags ? (
        <a
          href={`/blog?tag=${encodeURIComponent(tag)}`}
          class={`${tagClass} hover:bg-brand-tint-strong transition-colors`}
        >
          {tag}
        </a>
      ) : (
        <span class={tagClass}>{tag}</span>
      )
    ))}
  </div>
  <h1 class="text-3xl font-bold text-ink mb-3 leading-tight">{title}</h1>
  <time class="text-sm text-faint">{formatted}</time>
</div>
