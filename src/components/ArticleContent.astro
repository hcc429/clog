<div class="prose prose-gray max-w-none
  prose-headings:font-bold prose-headings:text-ink
  prose-a:text-brand prose-a:no-underline hover:prose-a:underline
  prose-img:rounded-lg prose-img:shadow-sm
  prose-blockquote:border-brand-soft prose-blockquote:text-muted
  [&_:not(pre)>code]:before:content-none [&_:not(pre)>code]:after:content-none
  [&_:not(pre)>code]:bg-brand-tint [&_:not(pre)>code]:text-brand-strong
  [&_:not(pre)>code]:px-1.5 [&_:not(pre)>code]:py-0.5 [&_:not(pre)>code]:rounded
  [&_pre]:rounded-xl [&_pre]:border [&_pre]:border-line [&_pre]:overflow-x-auto">
  <slot />
</div>
