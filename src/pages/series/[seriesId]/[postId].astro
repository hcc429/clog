---
import SeriesPostLayout from "../../../layouts/SeriesPostLayout.astro";
import { getCollection, render } from "astro:content";
import { getSeriesPostSlug, getSeriesSlug } from "../../../lib/routes";

export async function getStaticPaths() {
  const posts = await getCollection("seriesPosts", ({ data }) => !data.draft);
  return posts.map((post) => {
    const seriesId = getSeriesSlug(post.id);
    const postId = getSeriesPostSlug(post.id);
    return { params: { seriesId, postId }, props: { post } };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<SeriesPostLayout post={post}>
  <Content />
</SeriesPostLayout>
